// Creates dynamic format strings with optional thousand separators, decimals, negative brackets, and delta icons. Example: 1000000 with K multiplier → "1.0K▲"
function 'Tharun.FormatString.GetDynamicFormatString' =
		(
			Val: anyref, numberOfDecimalPlaces: numeric, 
			thousandSeperator: boolean, 
			multiplesOfThousand: boolean, 
			negativeNumbersBracket: boolean, 
			truncateZero:boolean, deltaIcon: boolean
		) =>
			VAR __AbsVal = ABS(Val)
			VAR __decimalPart = IF(
				numberOfDecimalPlaces > 0,
				"." & REPT(
					"0",
					numberOfDecimalPlaces
				),
				""
			)
			VAR __MultiplesOfThousand = IF(
				multiplesOfThousand,
				SWITCH(
					TRUE(),
					__AbsVal >= 1e12, ",,,," & __decimalPart & "T",
					__AbsVal >= 1e9, ",,," & __decimalPart & "B",
					__AbsVal >= 1e6, ",," & __decimalPart & "M",
					__AbsVal >= 1e3, "," & __decimalPart & "K",
					"" & __decimalPart
				),
				"" & __decimalPart
			)
			VAR __DigitWithThousandSeperator = "#,0"
			VAR __DigitWithoutThousandSeperator = "0"
			VAR __NumericFormatString = IF(
				thousandSeperator,
				__DigitWithThousandSeperator & __MultiplesOfThousand,
				__DigitWithoutThousandSeperator & __MultiplesOfThousand
			)
			VAR __PositiveFormatString = __NumericFormatString & IF(
				deltaIcon,
				"▲",
				""
			)
	
			VAR __NegativeFormatString = IF(
				negativeNumbersBracket,
				";(" & __NumericFormatString & ")",
				";-" & __NumericFormatString
			) & IF(
				deltaIcon,
				"▼"
			)
			VAR __FormatString = __PositiveFormatString & __NegativeFormatString & IF(truncateZero, ";0","")
			RETURN
				__FormatString

	annotation DAXLIB_PackageId = Tharun.FormatString
	annotation DAXLIB_PackageVersion = 0.2.0


// Creates numeric format strings with custom delta icons for positive/negative values. Example: -5000 with brackets and custom icon → "(5.0K)▼"
function 'Tharun.FormatString.GetNumericDynamicFormatString' =
			(
                Val: anyref, numberOfDecimalPlaces: numeric, 
                thousandSeperator: boolean, 
                multiplesOfThousand: boolean, 
                negativeNumbersBracket: boolean, 
                truncateZero: boolean, deltaIconRequired: boolean, 
                preferredPositiveDeltaIcon: string, 
                preferredNegativeDeltaIcon: string
            ) =>
                VAR __AbsVal = ABS(Val)
                VAR __decimalPart = IF(
                    numberOfDecimalPlaces > 0,
                    "." & REPT(
                        "0",
                        numberOfDecimalPlaces
                    ),
                    ""
                )
                VAR __MultiplesOfThousand = IF(
                    multiplesOfThousand,
                    SWITCH(
                        TRUE(),
                        __AbsVal >= 1e12, ",,,," & __decimalPart & "T",
                        __AbsVal >= 1e9, ",,," & __decimalPart & "B",
                        __AbsVal >= 1e6, ",," & __decimalPart & "M",
                        __AbsVal >= 1e3, "," & __decimalPart & "K",
                        "" & __decimalPart
                    ),
                    "" & __decimalPart
                )
                VAR __DigitWithThousandSeperator = "#,0"
                VAR __DigitWithoutThousandSeperator = "0"
                VAR __NumericFormatString = IF(
                    thousandSeperator,
                    __DigitWithThousandSeperator & __MultiplesOfThousand,
                    __DigitWithoutThousandSeperator & __MultiplesOfThousand
                )
                VAR __PositiveFormatString = __NumericFormatString & IF(
                    deltaIconRequired,
                    " " &preferredPositiveDeltaIcon,
                    ""
                )
                VAR __NegativeFormatString = IF(
                    negativeNumbersBracket,
                    ";(" & __NumericFormatString & ")",
                    ";-" & __NumericFormatString
                ) & IF(
                    deltaIconRequired,
                    " "&preferredNegativeDeltaIcon
                )
                VAR __FormatString = __PositiveFormatString & __NegativeFormatString & IF(
                    truncateZero,
                    ";0",
                    ""
                )
                RETURN
                    __FormatString
	annotation DAXLIB_PackageId = Tharun.FormatString
	annotation DAXLIB_PackageVersion = 0.2.0


// Creates percentage format strings with custom delta icons. Example: 0.85 with 2 decimals → "85.00% ▲"
function 'Tharun.FormatString.GetPercentageDynamicFormatString' = 
			(
                Val: anyref, numberOfDecimalPlaces: numeric, 
                inputIsPercentage: boolean, 
                negativeNumbersBracket: boolean, 
                truncateZero: boolean, deltaIconRequired: boolean, 
                preferredPositiveDeltaIcon: string, 
                preferredNegativeDeltaIcon: string
            ) =>
                VAR __AbsVal = ABS(Val)
                VAR __PercentageSymbol = IF(inputIsPercentage, "\%", "%")
                VAR __decimalPart = IF(
                    numberOfDecimalPlaces > 0,
                    "." & REPT(
                        "0",
                        numberOfDecimalPlaces
                    ),
                    ""
                ) & __PercentageSymbol
                VAR __PositiveFormatString = __decimalPart & IF(
                    deltaIconRequired,
                    " " & preferredPositiveDeltaIcon,
                    ""
                ) 
                VAR __NegativeFormatString = IF(
                    negativeNumbersBracket,
                    ";(" & __decimalPart & ")",
                    ";-" & __decimalPart
                ) & IF(
                    deltaIconRequired,
                    " "& preferredNegativeDeltaIcon
                ) 
                VAR __FormatString = __PositiveFormatString & __NegativeFormatString & IF(
                    truncateZero,
                    ";0"& __PercentageSymbol,
                    ""
                )
                RETURN
                    __FormatString
        
	annotation DAXLIB_PackageId = Tharun.FormatString
	annotation DAXLIB_PackageVersion = 0.2.0
