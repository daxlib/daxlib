/// Performs the Anderson-Darling test for  the composite hypothesis of normality, see e.g. Thode (2002, Sec. 5.1.4). 
/// Takes a table and a column reference to the values as input parameter. 
/// Thanks to Juergen Gross for the R implementation in the nortest library.
function 'Nortest.AndersonDarlingTest.ADTEST' =
	( 
		xTable : TABLE EXPR,
		valuesColumn : ANYREF EXPR
	) =>
	VAR _ValuesTable =
		FILTER (
			SELECTCOLUMNS (
				xTable,
				"Value", valuesColumn
			),
			NOT ISBLANK ( [Value] )
		)

	VAR _N =
		COUNTROWS ( xTable )

	VAR _MinX =
		MINX ( _ValuesTable, [Value] )

	VAR _MaxX =
		MAXX ( _ValuesTable, [Value] )

	RETURN
	SWITCH (
		TRUE (),
			_N < 8, ERROR ( "sample size must be greater than 7" ),
		COUNTROWS ( _ValuesTable ) < 8,
			ERROR ( "not enough non-blank values in list" ),
		_MinX = _MaxX, 
			0,

		VAR _MeanX =
			AVERAGEX ( _ValuesTable, [Value] )

		VAR _SdX =
			STDEVX.S ( _ValuesTable, [Value] )

		VAR _GroupedBase =
			GROUPBY (
				_ValuesTable,
				[Value],
				"c", COUNTX ( CURRENTGROUP (), 1 )
			)

		VAR _Grouped =
			ADDCOLUMNS (
				_GroupedBase,
				"EndPos",
					VAR _CurX = [Value]
					RETURN
						SUMX (
							FILTER ( _GroupedBase, [Value] <= _CurX ),
							[c]
						),
				"StartPos",
					VAR _CurX = [Value]
					VAR _CurC = [c]
					VAR _EndPos =
						SUMX (
							FILTER ( _GroupedBase, [Value] <= _CurX ),
							[c]
						)
					RETURN
						_EndPos - _CurC + 1,
				"LogP1",
					VAR _Z1 =
						DIVIDE ( [Value] - _MeanX, _SdX )
					VAR _Cdf1 =
						NORM.S.DIST ( _Z1, TRUE )
					VAR _SafeCdf1 =
						MIN ( 1 - 1e-15, MAX ( 1e-15, _Cdf1 ) )
					RETURN
						LN ( _SafeCdf1 ),
				"LogP2",
					VAR _Z2 =
						DIVIDE ( [Value] - _MeanX, _SdX )
					VAR _Cdf2 =
						NORM.S.DIST ( _Z2, TRUE )
					VAR _SafeTail =
						MIN ( 1 - 1e-15, MAX ( 1e-15, 1 - _Cdf2 ) )
					RETURN
						LN ( _SafeTail )
			)

		VAR _H =
			SUMX (
				_Grouped,
				VAR _S = [StartPos]
				VAR _E = [EndPos]
				VAR _C = [c]
				VAR _CoeffLogP1 =
					_E * _E - ( _S - 1 ) * ( _S - 1 )
				VAR _CoeffLogP2 =
					_C * ( 2 * _N + 1 - _S - _E )
				RETURN
					_CoeffLogP1 * [LogP1]
						+ _CoeffLogP2 * [LogP2]
			)

		VAR _A2 =
			-_N - DIVIDE ( _H, _N )

		VAR _AA =
			( 1 + DIVIDE ( 0.75, _N ) + DIVIDE ( 2.25, _N * _N ) ) * _A2

		VAR _PValue =
			SWITCH (
				TRUE (),
				_AA < 0.2,
					1 - EXP ( -13.436 + 101.14 * _AA - 223.73 * _AA * _AA ),
				_AA < 0.34,
					1 - EXP ( -8.318 + 42.796 * _AA - 59.938 * _AA * _AA ),
				_AA < 0.6,
					EXP ( 0.9177 - 4.279 * _AA - 1.38 * _AA * _AA ),
				_AA < 10,
					EXP ( 1.2937 - 5.709 * _AA + 0.0186 * _AA * _AA ),
				0
			)

		RETURN
			_PValue
	)

	annotation DAXLIB_PackageId = Nortest.AndersonDarlingTest.ADTEST

	annotation DAXLIB_PackageVersion = 1.0.0
