/// Add a name/value pair to an encoded parameter string
/// If the parameter name already exists, it will be duplicated (not replaced)
/// @param {string} encodedString - The encoded parameter string
/// @param {string} parameterName - The name of the parameter
/// @param {string} parameterValue - The value of the parameter
/// @return String with the encoded parameter string
function 'DaxLib.Records.AddRecordValue' = ```
    (
        encodedString : STRING VAL,
        parameterName : STRING VAL,
        parameterValue : STRING VAL
    ) =>
    VAR AssignmentSeparator = DaxLib.Records.Internals.AssignmentSeparator()
    VAR ItemSeparator = DaxLib.Records.Internals.ItemSeparator()

    // Create the new parameter pair
    VAR NewPair = parameterName & AssignmentSeparator & parameterValue & ItemSeparator

    // Append to existing string
    VAR Result = encodedString & NewPair

    RETURN Result
    ```
    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

/// Function to retrieve a value given a parameter name from an encoded string
/// If the parameter is not found, it raises an error. 
/// Use GetRecordValueDefault if you want to return a default value instead of raising an error.
/// @param {string} encodedString - The encoded parameter string
/// @param {string} parameterName - The name of the parameter
/// @return String with the value of the parameter
function 'DaxLib.Records.GetRecordValue' = ```
    (
        encodedString : STRING VAL,
        parameterName : STRING VAL
    ) =>
    VAR ErrorDefaultValue = "__*_ERROR_VALUE_*__"
    VAR Result = DaxLib.Records.GetRecordValueDefault(encodedString, parameterName, ErrorDefaultValue)
    RETURN IF ( 
        Result = ErrorDefaultValue,
        ERROR("Parameter not found by GetRecordValue"),
        Result
    )
    ```
    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

/// Function to retrieve a value given a parameter name from an encoded string
/// @param {string} encodedString - The encoded parameter string
/// @param {string} parameterName - The name of the parameter
/// @param {string} defaultValue - The default value to return if the parameter is not found
/// @return String with the value of the parameter
function 'DaxLib.Records.GetRecordValueDefault' = ```
    (
        encodedString : STRING VAL,
        parameterName : STRING VAL,
        defaultValue : STRING VAL
    ) =>
    VAR AssignmentSeparator = DaxLib.Records.Internals.AssignmentSeparator()
    VAR ItemSeparator = DaxLib.Records.Internals.ItemSeparator()

    // Normalize string to ensure trailing item separator
    VAR NormalizedString = DaxLib.Records.Internals.GetNormalizedString(encodedString)

    // Search for the parameter name followed by assignment separator
    VAR SearchPattern = parameterName & AssignmentSeparator
    VAR NamePosition = FIND(SearchPattern, NormalizedString, 1, 0)

    // Extract the value if found
    VAR Result = 
        IF(
            NamePosition = 0,
            defaultValue,
            VAR ValueStart = NamePosition + LEN(SearchPattern)
            VAR RemainingString = MID(NormalizedString, ValueStart, LEN(NormalizedString))
            VAR ValueEnd = FIND(ItemSeparator, RemainingString, 1, 0)
            VAR ExtractedValue = LEFT(RemainingString, ValueEnd - 1)
            RETURN ExtractedValue
        )

    RETURN Result
    ```
    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

/// Function to retrieve a value given a parameter name from an encoded string
/// @param {string} encodedString - The encoded parameter string
/// @param {string} parameterName - The name of the parameter
/// @return Boolean indicating if the parameter exists
function 'DaxLib.Records.HasRecordValue' = ```
    (
        encodedString : STRING VAL,
        parameterName : STRING VAL
    ) =>
    VAR NamePosition = DaxLib.Records.Internals.FindNamePosition(encodedString, parameterName)

    // Returns whether the parameter exists
    VAR Result = (NamePosition > 0)

    RETURN Result
    ```
    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

/// Separator used to delimit parameter name from parameter value in the encoded string
/// (internal use only, not intended for external consumption)
/// @return String value of the separator
function 'DaxLib.Records.Internals.AssignmentSeparator' = () => "|~|" 

    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

/// Get the position of a parameter name within the encoded string, which can be used to determine if it exists and where its value starts
/// Format: name1[AS]value1[IS]name2[AS]value2[IS]
/// [AS] = Assignment Separator - separates name from value
/// [IS] = Item Separator - separates pairs
/// @param {string} encodedString - The encoded parameter string
/// @param {string} parameterName - The name of the parameter to find
/// @return Character position of the parameter name within the encoded string
function 'DaxLib.Records.Internals.FindNamePosition' = ```
    (
        encodedString : STRING VAL,
        parameterName : STRING VAL
    ) =>
    VAR AssignmentSeparator = DaxLib.Records.Internals.AssignmentSeparator()
    VAR ItemSeparator = DaxLib.Records.Internals.ItemSeparator()

    // Normalize string to ensure trailing item separator
    VAR NormalizedString = DaxLib.Records.Internals.GetNormalizedString(encodedString)

    // Search for the parameter name followed by assignment separator
    VAR SearchPattern = parameterName & AssignmentSeparator
    VAR NamePosition = FIND(SearchPattern, NormalizedString, 1, 0)

    RETURN NamePosition
    ```
    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

/// Get the normalized string by ensuring it ends with the item separator, which simplifies parsing logic in other functions
/// @param {string} encodedString - The encoded parameter string
/// @return String normalized encoded string
function 'DaxLib.Records.Internals.GetNormalizedString' = ```
    (
        encodedString : STRING VAL
    ) =>
    VAR AssignmentSeparator = DaxLib.Records.Internals.AssignmentSeparator()
    VAR ItemSeparator = DaxLib.Records.Internals.ItemSeparator()

    // Normalize string to ensure trailing item separator
    VAR NormalizedString = 
        IF(
            RIGHT(encodedString, LEN(ItemSeparator)) = ItemSeparator,
            encodedString,
            encodedString & ItemSeparator
        )

    RETURN NormalizedString
    ```
    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

/// Separator used to delimit parameter pairs in the encoded string
/// (internal use only, not intended for external consumption)
/// @return String value of the separator
function 'DaxLib.Records.Internals.ItemSeparator' = () => ";~;"

    annotation DAXLIB_PackageId = DaxLib.Records
    annotation DAXLIB_PackageVersion = 0.9.0-beta

